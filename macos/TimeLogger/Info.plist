<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>TimeLogger</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSUIElement</key>
	<false/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>TimeLogger advertises a BLE peripheral so your iPhone and Apple Watch can sync timers instantly when nearby.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_tl._tcp</string>
	</array>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>TimeLogger reads your calendar to suggest timers based on the event you're currently in or about to start.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>TimeLogger browses your Wi-Fi for other Macs running the tl daemon so the mesh of your Apple devices stays in sync.</string>
</dict>
</plist>
